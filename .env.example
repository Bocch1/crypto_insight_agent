# ==========================================
# Crypto Insight Agent - 环境变量配置模板
# ==========================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填入你的真实API密钥
# 3. .env 文件不会被提交到git（已在.gitignore中）
# ==========================================

# === DeepSeek API 配置 ===
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === 币安 API 配置 ===
# 公开接口不需要key，如需更高频次请注册：
# https://www.binance.com/zh-CN/support/faq/360002502072
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# === Etherscan API 配置 ===
# 免费注册获取：https://etherscan.io/register
# 注册后在这里创建API Key：https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# === News API 配置（可选）===
# 获取地址：https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# === LangSmith 配置（可选，用于调试追踪）===
# 获取地址：https://smith.langchain.com/
LANGCHAIN_API_KEY=lsv2_your_langsmith_api_key_here
LANGCHAIN_PROJECT=crypto-insight-agent

# === 应用配置 ===
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 缓存时间（秒）
CACHE_TTL=300

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 最大重试次数
MAX_RETRIES=3